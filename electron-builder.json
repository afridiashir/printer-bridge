{
  "appId": "com.company.printerbridge",

  "productName": "PrinterBridge",

  "directories": {
    "output": "release"
  },

  "files": [
    "dist/**/*",
    "renderer/**/*",
    "assets/**/*",
    "node_modules/**/*",
    "package.json"
  ],

  "win": {
    "target": "nsis"
  },

  "nsis": {
    "oneClick": true,
    "allowToChangeInstallationDirectory": false
  }
}