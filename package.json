{
  "name": "printer-bridge",
  "version": "1.0.0",
  "description": "",
  "main": "dist/electron/main.js",
  "type": "commonjs",

  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "dist": "npm run build && electron-builder"
  },

  "build": {
    "appId": "com.company.printerbridge",
    "productName": "PrinterBridge",

    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],

    "win": {
      "target": "nsis"
    },

    "directories": {
      "output": "release"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "escpos": "^3.0.0-alpha.6",
    "express": "^5.2.1",
    "node-thermal-printer": "^4.6.0",
    "pdf-to-printer": "^5.8.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
